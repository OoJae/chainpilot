# AVE Cloud API (required)
AVE_API_KEY=your_ave_api_key_here
AVE_SECRET_KEY=your_ave_secret_key_here
API_PLAN=pro                          # free | normal | pro (pro required for WSS streaming)

# Legacy trade helper (chainpilot_trade.py only)
AVE_ACCESS_KEY=your_ave_access_key_here
AVE_ASSETS_ID=your_assets_id_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Website (optional)
PORT=3000                             # Landing page server port
